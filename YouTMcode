import flet as ft
import sqlite3


conn = sqlite3.connect("you.db", check_same_thread=False)
cursor = conn.cursor()


cursor.execute("""
CREATE TABLE IF NOT EXISTS users (
   id INTEGER PRIMARY KEY AUTOINCREMENT,
   name TEXT UNIQUE,
   age TEXT
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS results (
   user_id INTEGER,
   score INTEGER,
   category TEXT,
   FOREIGN KEY(user_id) REFERENCES users(id)
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS votes (
  voter_name TEXT,
  voted_user_id INTEGER,
  FOREIGN KEY(voted_user_id) REFERENCES users(id)
)
""")

conn.commit()

def calculate_score(answers):
   raw = sum(answers)
   max_score = len(answers) * 10
   score = int((raw / max_score) * 100)


   if score <= 30:
       category = "Standard"
   elif score <= 60:
       category = "Rising"
   elif score <= 85:
       category = "Trending"
   else:
       category = "Premium"


   return score, category




def main(page: ft.Page):
   page.title = "YOU™"
   page.scroll = "auto"
   page.theme_mode = "dark"


   def render_home():
       page.controls.clear()


       page.add(
           ft.Container(
               expand=True,
               alignment=ft.alignment.center,
               content=ft.Column(
                   [
                       ft.Text("YOU™", size=40, weight="bold"),
                       ft.Text("Social Value Simulator", size=16, color="grey"),
                       ft.ElevatedButton("Start Profile", on_click=lambda e: render_form()),
                       ft.ElevatedButton("View Leaderboard", on_click=lambda e: render_leaderboard()),
                       ft.ElevatedButton("Vote", on_click=lambda e: render_vote())
                   ],

                   alignment=ft.MainAxisAlignment.CENTER,
                   horizontal_alignment=ft.CrossAxisAlignment.CENTER,
                   expand=True
               )
           )
       )


   def render_form():
       page.controls.clear()


       name_input = ft.TextField(label="Name")
       
       age_input = ft.TextField(label="Age")


       def create_question(title, options):
           return ft.RadioGroup(
               content=ft.Column([
                   ft.Text(title, weight="bold"),
                   *[ft.Radio(value=str(points), label=label) for label, points in options]
               ])
           )


       questions = [
           create_question("How do you act under pressure?", [("Stay calm",10),("Stress",7),("Panic",4)]),
           create_question("How social are you?", [("Very social",10),("Balanced",7),("Introverted",4)]),
           create_question("Decision style", [("Fast",10),("Think first",7),("Indecisive",4)]),
           create_question("Risk level", [("High",10),("Medium",7),("Low",4)]),
           create_question("Work style", [("Leader",10),("Team",7),("Solo",6)]),
           create_question("Energy level", [("High",10),("Medium",7),("Low",4)])
       ]


       result_text = ft.Text(size=16)


       def submit(e):
           if not name_input.value or not age_input.value:
               result_text.value = "⚠️ Fill all fields"
               page.update()
               return
           
           if not age_input.value.isdigit():
            result_text.value = "⚠️ Age must be a number"
            page.update()

            age = int(age_input.value)
            return

           if age < 1 or age > 100:
            result_text.value = "⚠️ Error: age must be between 1 and 100"
            page.update()
            return

           if any(q.value is None for q in questions):
               result_text.value = "⚠️ Answer all questions"
               page.update()
               return


           answers = [int(q.value) for q in questions]
           score, category = calculate_score(answers)


           try:
               cursor.execute(
                   "INSERT INTO users (name, age) VALUES (?, ?)",
                   (name_input.value, age_input.value)
               )
               user_id = cursor.lastrowid
           except sqlite3.IntegrityError:
               cursor.execute("SELECT id FROM users WHERE name = ?", (name_input.value,))
               user_id = cursor.fetchone()[0]


           cursor.execute("DELETE FROM results WHERE user_id = ?", (user_id,))
           cursor.execute(
               "INSERT INTO results (user_id, score, category) VALUES (?, ?, ?)",
               (user_id, score, category)
           )

           conn.commit()

           if category == "Standard":
            msg = "You're just getting started."
           elif category == "Rising":
            msg = "You're improving fast."
           elif category == "Trending":
            msg = "You're doing really well."
           else:
            msg = "You're top tier."


           result_text.value = f"🔥 Score: {score} | {category}\n{msg}"

           page.update()


       page.add(
           ft.Container(
               content=ft.Column([
                   ft.Text("Create Profile", size=24),
                   name_input,
                   age_input,
                   *questions,
                   ft.Row([
                       ft.ElevatedButton("Submit", on_click=submit),
                       ft.OutlinedButton("Back", on_click=lambda e: render_home())
                   ]),
                   result_text
               ]),
               padding=20
           )
       )

   def render_vote():
      page.controls.clear()


      cursor.execute("SELECT id, name FROM users")
      users = cursor.fetchall()


      voter_name = ft.TextField(label="Your Name")
      selected_user = ft.Dropdown(label="Vote for")


      for u in users:
          selected_user.options.append(ft.dropdown.Option(str(u[0]), u[1]))


      result_text = ft.Text()


      def submit_vote(e):
          if not voter_name.value or not selected_user.value:
              result_text.value = "⚠️ Fill all fields"
              page.update()
              return


          cursor.execute("SELECT COUNT(*) FROM users")
          count = cursor.fetchone()[0]


          if count > 1:
              cursor.execute(
                  "INSERT INTO votes (voter_name, voted_user_id) VALUES (?, ?)",
                  (voter_name.value, int(selected_user.value))
              )


              cursor.execute(
                  "UPDATE results SET score = score + 10 WHERE user_id = ?",
                  (int(selected_user.value),)
              )


              conn.commit()
              result_text.value = "Vote submitted! (+10 pts)"
          else:
              result_text.value = "First user, no vote needed"


          page.update()


      page.add(
          ft.Column([
              ft.Text("Vote for a Profile", size=24),
              voter_name,
              selected_user,
              ft.ElevatedButton("Submit Vote", on_click=submit_vote),
              ft.OutlinedButton("Back", on_click=lambda e: render_home()),
              result_text
          ])
      )

   def render_leaderboard():
       page.controls.clear()


       cursor.execute("""
       SELECT users.name, results.score, results.category
       FROM users
       JOIN results ON users.id = results.user_id
       ORDER BY results.score DESC
       """)


       rows = cursor.fetchall()


       medals = ["🥇", "🥈", "🥉"]


       table = ft.ListView(expand=True, spacing=10)


       if not rows:
           table.controls.append(ft.Text("No data yet"))
       else:
           for i, r in enumerate(rows, start=1):
               medal = medals[i-1] if i <= 3 else f"#{i}"
               table.controls.append(
                   ft.Container(
                       content=ft.Row([
                           ft.Text(medal, size=20),
                           ft.Text(r[0], weight="bold"),
                           ft.Text(f"{r[1]} pts"),
                           ft.Text(r[2], color="blue")
                       ], alignment="spaceBetween"),
                       padding=10,
                       border_radius=10,
                       bgcolor="#1e1e1e"
                   )
               )


       page.add(
           ft.Column([
               ft.Text("🏆 Leaderboard", size=28),
               table,
               ft.ElevatedButton("Back", on_click=lambda e: render_home())
           ], expand=True)
       )


   render_home()




ft.app(target=main)
